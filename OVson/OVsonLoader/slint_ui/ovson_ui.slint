import { ScrollView } from "std-widgets.slint";
export struct LogLine {
    text: string,
    color: color,
}

export struct PRow {
    pid: int,
    title: string,
    selected: bool,
    injected: bool,
    progress: int,
    stage: string,
    working: bool,
    finished-ok: bool,
    finished-fail: bool,
    launcher-label: string,    // "Vanilla" | "Lunar" | "Badlion" | …
    launcher-color: color,     // chip background colour
    mc-version: string,        // "1.8.9", "" if unknown
    memory-text: string,       // "2.1 GB", "" if unknown
    uptime-text: string,       // "12m", "1h 4m"
}

global Palette {
    out property <color> bg:           #0a0a0d;
    out property <color> panel:        #131319;
    out property <color> card:         #17181e;
    out property <color> card-hover:   #1e1f26;
    out property <color> card-select:  #21232c;
    out property <color> card-inj:     #122520;
    out property <color> border:       #20212a;
    out property <color> border-hover: #38394044;
    out property <color> accent:       #5eead4;
    out property <color> accent-dim:   #2d6e62;
    out property <color> text:         #f6f7fa;
    out property <color> text-dim:     #a1a1aa;
    out property <color> text-muted:   #71717a;
    out property <color> success:      #10b981;
    out property <color> error-c:      #ef4444;
    out property <color> disabled:     #3b3d44;
}

component InfoChip inherits Rectangle {
    in property <string> label;
    in property <color>  accent: Palette.text-muted;
    in property <bool>   filled: false;

    height: 18px;
    border-radius: 9px;
    background: filled ? accent : transparent;
    border-width: filled ? 0px : 1px;
    border-color: Palette.border-hover;

    HorizontalLayout {
        padding-left: 7px;
        padding-right: 7px;
        alignment: center;
        Text {
            text: root.label;
            color: filled ? Palette.bg : accent;
            font-size: 10px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }
}

component ProcessCard inherits Rectangle {
    in property <PRow> data;
    callback clicked();
    callback uninject-clicked();
    callback right-clicked();

    height: 92px;
    border-radius: 10px;
    border-width: 1px;

    background: data.injected      ? Palette.card-inj
              : data.selected      ? Palette.card-select
              : touch.has-hover    ? Palette.card-hover
                                   : Palette.card;
    animate background { duration: 160ms; easing: ease-out; }

    border-color: data.injected ? Palette.accent-dim
                : data.selected ? Palette.accent
                                : Palette.border;
    animate border-color { duration: 160ms; easing: ease-out; }

    touch := TouchArea {
        mouse-cursor: data.injected ? MouseCursor.default : MouseCursor.pointer;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.up
                && ev.button == PointerEventButton.left
                && !data.injected) {
                root.clicked();
            }
            if (ev.kind == PointerEventKind.up
                && ev.button == PointerEventButton.right) {
                root.right-clicked();
            }
        }
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 14px;
        alignment: stretch;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 16px;
                height: 16px;
                border-radius: 4px;
                border-width: 1px;
                background: data.selected || data.injected
                            ? Palette.accent : transparent;
                border-color: data.selected || data.injected
                              ? Palette.accent : Palette.border-hover;
                animate background, border-color {
                    duration: 140ms; easing: ease-out;
                }
                if data.selected || data.injected: Image {
                    width: 12px;
                    height: 12px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    colorize: Palette.bg;
                    source: @image-url("check.svg");
                }
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 4px;
            horizontal-stretch: 1;

            Text {
                text: data.title;
                color: Palette.text;
                font-size: 15px;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: data.working       ? "PID \{data.pid}  •  \{data.stage} (\{data.progress}%)"
                    : data.finished-fail ? "PID \{data.pid}  •  \{data.stage}"
                    : data.injected      ? "PID \{data.pid}  •  Already injected"
                    : data.finished-ok   ? "PID \{data.pid}  •  Injected"
                                         : "PID \{data.pid}";
                color: data.finished-fail ? Palette.error-c
                     : data.working       ? Palette.accent
                     : data.injected      ? Palette.accent
                     : data.finished-ok   ? Palette.success
                                          : Palette.text-muted;
                font-size: 11px;
                animate color { duration: 200ms; }
            }
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                if data.launcher-label != "" && data.launcher-label != "Unknown":
                  InfoChip {
                    label: data.launcher-label;
                    accent: data.launcher-color;
                    filled: true;
                  }
                if data.mc-version != "": InfoChip {
                    label: data.mc-version;
                    accent: Palette.text-dim;
                }
                if data.memory-text != "": InfoChip {
                    label: data.memory-text;
                    accent: Palette.text-muted;
                }
                if data.uptime-text != "": InfoChip {
                    label: data.uptime-text;
                    accent: Palette.text-muted;
                }
            }
        }

        VerticalLayout {
            alignment: center;
            width: 100px;

            if data.injected: Rectangle {
                height: 30px;
                border-radius: 6px;
                border-width: 1px;
                background: uninject-touch.has-hover ? #2a1a1a : #1e1418;
                border-color: uninject-touch.has-hover ? Palette.error-c : #3a2020;
                animate background, border-color { duration: 140ms; easing: ease-out; }

                uninject-touch := TouchArea {
                    clicked => { root.uninject-clicked(); }
                    mouse-cursor: MouseCursor.pointer;
                }

                Text {
                    text: "UNINJECT";
                    font-size: 10px;
                    font-weight: 700;
                    color: uninject-touch.has-hover ? Palette.error-c : #cc6666;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    animate color { duration: 140ms; }
                }
            }

            if !data.injected && (data.working || data.finished-ok || data.finished-fail): Rectangle {
                height: 6px;
                background: #28282f;
                border-radius: 3px;

                Rectangle {
                    x: 0;
                    y: 0;
                    height: parent.height;
                    width: parent.width * data.progress / 100;
                    border-radius: 3px;
                    background: data.finished-fail ? Palette.error-c
                              : data.finished-ok   ? Palette.success
                                                   : Palette.accent;
                    animate width, background { duration: 220ms; easing: ease-out; }
                }
            }
        }
    }
}

component PrimaryButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    callback clicked();

    height: 44px;
    width: 320px;
    border-radius: 10px;

    background: !enabled            ? Palette.disabled
              : touch.pressed       ? #cbcdd2
              : touch.has-hover     ? #ffffff
                                    : #ebecf0;
    animate background { duration: 130ms; easing: ease-out; }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
    }

    Text {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        text: label;
        font-size: 14px;
        font-weight: 600;
        color: enabled ? Palette.bg : Palette.text-muted;
        animate color { duration: 160ms; }
    }
}

component NavButton inherits Rectangle {
    in property <string> label;
    in property <bool>   active: false;
    callback clicked();

    height: 26px;
    width: 78px;
    border-radius: 6px;

    background: active           ? Palette.card-select
              : touch.has-hover  ? Palette.card-hover
                                 : transparent;
    animate background { duration: 140ms; easing: ease-out; }

    touch := TouchArea {
        clicked => { root.clicked(); }
        mouse-cursor: MouseCursor.pointer;
    }

    Text {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        text: label;
        color: active ? Palette.accent : Palette.text-dim;
        font-size: 11px;
        font-weight: active ? 700 : 600;
        animate color { duration: 140ms; }
    }
}

component AboutPage inherits Rectangle {
    in property <string> build-version: "0.0.0";
    callback open-github();

    background: transparent;

    VerticalLayout {
        padding: 36px;
        spacing: 18px;
        alignment: center;

        Image {
            source: @image-url("ovson_logo.png");
            image-fit: contain;
            width: 96px;
            height: 96px;
            horizontal-alignment: center;
        }
        Text {
            text: "OVson";
            color: Palette.text;
            font-size: 28px;
            font-weight: 800;
            horizontal-alignment: center;
        }
        Text {
            text: "Bedwars overlay client · v" + build-version;
            color: Palette.text-dim;
            font-size: 12px;
            horizontal-alignment: center;
        }
        Rectangle {
            height: 1px;
            background: Palette.border;
        }
        Text {
            text: "Made with ♥ by alperenproo";
            color: Palette.text-muted;
            font-size: 11px;
            horizontal-alignment: center;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: center;
            Rectangle {
                width: 130px; height: 32px; border-radius: 8px;
                background: gh-touch.has-hover ? Palette.card-hover : Palette.card;
                border-width: 1px;
                border-color: Palette.border-hover;
                animate background { duration: 140ms; }
                gh-touch := TouchArea {
                    clicked => { root.open-github(); }
                    mouse-cursor: MouseCursor.pointer;
                }
                Text {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    text: "GitHub";
                    color: Palette.text;
                    font-size: 11px;
                    font-weight: 600;
                }
            }
        }
    }
}

component LogsPage inherits Rectangle {
    in property <[LogLine]> lines;
    in property <string>    log-path;
    callback open-log-folder();
    callback clear-log();

    background: transparent;

    VerticalLayout {
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 18px;
        padding-bottom: 18px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 10px;
            alignment: stretch;

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 2px;
                Text {
                    text: "Live log";
                    color: Palette.text;
                    font-size: 20px;
                    font-weight: 700;
                }
                Text {
                    text: log-path != "" ? log-path : "Waiting for an injected session…";
                    color: Palette.text-muted;
                    font-size: 10px;
                    overflow: elide;
                }
            }
            Rectangle {
                width: 96px; height: 28px;
                y: (parent.height - self.height) / 2;
                border-radius: 6px;
                background: open-touch.has-hover
                            ? Palette.card-hover : transparent;
                border-width: 1px;
                border-color: Palette.border-hover;
                open-touch := TouchArea {
                    clicked => { root.open-log-folder(); }
                    mouse-cursor: MouseCursor.pointer;
                }
                Text {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    text: "Open folder";
                    color: Palette.text-dim;
                    font-size: 10px;
                    font-weight: 600;
                }
            }
            Rectangle {
                width: 72px; height: 28px;
                y: (parent.height - self.height) / 2;
                border-radius: 6px;
                background: clear-touch.has-hover
                            ? Palette.card-hover : transparent;
                border-width: 1px;
                border-color: Palette.border-hover;
                clear-touch := TouchArea {
                    clicked => { root.clear-log(); }
                    mouse-cursor: MouseCursor.pointer;
                }
                Text {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    text: "Clear";
                    color: Palette.text-dim;
                    font-size: 10px;
                    font-weight: 600;
                }
            }
        }

        Rectangle {
            background: #0d0d11;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            vertical-stretch: 1;
            clip: true;

            ScrollView {
                x: 0; y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;

                VerticalLayout {
                    padding: 10px;
                    spacing: 1px;
                    for line in lines: Text {
                        text: line.text;
                        color: line.color;
                        font-family: "Consolas";
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                    if lines.length == 0: Text {
                        text: "No log activity yet. Inject into a Minecraft instance to see live output.";
                        color: Palette.text-muted;
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}

component Toggle inherits Rectangle {
    in-out property <bool> value: false;
    callback toggled();

    width: 36px;
    height: 20px;
    border-radius: 10px;
    background: value ? Palette.accent : #2a2c34;
    animate background { duration: 160ms; easing: ease-out; }

    Rectangle {
        x: value ? parent.width - self.width - 2px : 2px;
        y: 2px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: #ffffff;
        animate x { duration: 160ms; easing: ease-out; }
    }

    TouchArea {
        clicked => {
            root.value = !root.value;
            root.toggled();
        }
        mouse-cursor: MouseCursor.pointer;
    }
}

component SettingRow inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;

    height: 64px;
    background: transparent;

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 14px;
        alignment: stretch;

        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 3px;
            Text {
                horizontal-stretch: 1;
                text: root.title;
                color: Palette.text;
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: left;
            }
            if subtitle != "": Text {
                horizontal-stretch: 1;
                text: subtitle;
                color: Palette.text-muted;
                font-size: 11px;
                horizontal-alignment: left;
                overflow: elide;
            }
        }

        Rectangle {
            width: 56px;
            background: transparent;
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: end;
                    @children
                }
            }
        }
    }
}

component SectionHeader inherits Rectangle {
    in property <string> label;
    height: 18px;
    background: transparent;
    Text {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: Palette.text-muted;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: left;
        vertical-alignment: center;
    }
}

component SettingsPage inherits Rectangle {
    in-out property <bool> auto-inject: false;
    in-out property <bool> start-with-windows: false;
    in-out property <bool> minimize-to-tray: true;
    in-out property <bool> auto-check-updates: true;
    in-out property <int>  dll-slot: 0;
    in property <string>   custom-dll-path: "";

    callback settings-changed();
    callback pick-custom-dll();

    background: transparent;

    ScrollView {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        viewport-width: root.width;

        VerticalLayout {
            width: root.width;
            padding-left: 28px;
            padding-right: 28px;
            padding-top: 18px;
            padding-bottom: 24px;
            spacing: 18px;

            Text {
                horizontal-stretch: 1;
                text: "Settings";
                color: Palette.text;
                font-size: 22px;
                font-weight: 700;
                horizontal-alignment: left;
            }

            VerticalLayout {
                spacing: 8px;
                SectionHeader { label: "BEHAVIOR"; }
                Rectangle {
                    background: Palette.card;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Palette.border;
                    clip: true;

                    VerticalLayout {
                        SettingRow {
                            title: "Auto-inject on detect";
                            subtitle: "Inject the moment a Minecraft instance is detected.";
                            Toggle {
                                value <=> root.auto-inject;
                                toggled => { root.settings-changed(); }
                            }
                        }
                        Rectangle { height: 1px; background: Palette.border; }
                        SettingRow {
                            title: "Minimize to tray on close";
                            subtitle: "Keep the loader running in the system tray when you close it.";
                            Toggle {
                                value <=> root.minimize-to-tray;
                                toggled => { root.settings-changed(); }
                            }
                        }
                        Rectangle { height: 1px; background: Palette.border; }
                        SettingRow {
                            title: "Start with Windows";
                            subtitle: "Launch the loader automatically when you sign in.";
                            Toggle {
                                value <=> root.start-with-windows;
                                toggled => { root.settings-changed(); }
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;
                SectionHeader { label: "UPDATES"; }
                Rectangle {
                    background: Palette.card;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Palette.border;
                    clip: true;
                    VerticalLayout {
                        SettingRow {
                            title: "Check for updates automatically";
                            subtitle: "Periodic background checks against the release feed.";
                            Toggle {
                                value <=> root.auto-check-updates;
                                toggled => { root.settings-changed(); }
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 8px;
                SectionHeader { label: "DLL SLOT"; }
                Rectangle {
                    background: Palette.card;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Palette.border;

                    VerticalLayout {
                        padding: 16px;
                        spacing: 12px;

                        VerticalLayout {
                            spacing: 3px;
                            Text {
                                horizontal-stretch: 1;
                                text: "Which OVson.dll the loader injects";
                                color: Palette.text;
                                font-size: 13px;
                                font-weight: 600;
                                horizontal-alignment: left;
                            }
                            Text {
                                horizontal-stretch: 1;
                                text: "Stable uses the bundled DLL. Pick Custom to point at a .dll on disk for testing your own build.";
                                color: Palette.text-muted;
                                font-size: 11px;
                                horizontal-alignment: left;
                                wrap: word-wrap;
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            for opt[i] in [{label: "Stable", idx: 0},
                                           {label: "Custom", idx: 2}]:
                            Rectangle {
                                height: 32px;
                                horizontal-stretch: 1;
                                border-radius: 7px;
                                background: root.dll-slot == opt.idx
                                            ? Palette.accent-dim
                                            : (slot-touch.has-hover
                                               ? Palette.card-hover
                                               : transparent);
                                border-width: 1px;
                                border-color: root.dll-slot == opt.idx
                                              ? Palette.accent
                                              : Palette.border-hover;
                                animate background, border-color {
                                    duration: 130ms;
                                }
                                slot-touch := TouchArea {
                                    clicked => {
                                        root.dll-slot = opt.idx;
                                        root.settings-changed();
                                        if (opt.idx == 2) {
                                            root.pick-custom-dll();
                                        }
                                    }
                                    mouse-cursor: MouseCursor.pointer;
                                }
                                Text {
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    text: opt.label;
                                    color: root.dll-slot == opt.idx
                                           ? Palette.text
                                           : Palette.text-dim;
                                    font-size: 11px;
                                    font-weight: root.dll-slot == opt.idx
                                                 ? 700 : 600;
                                }
                            }
                        }

                        if dll-slot == 2 && custom-dll-path != "": Rectangle {
                            background: #14151b;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Palette.border;
                            height: 30px;
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                alignment: start;
                                Text {
                                    text: custom-dll-path;
                                    color: Palette.text-dim;
                                    font-size: 10px;
                                    font-family: "Consolas";
                                    overflow: elide;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "OVson";
    icon: @image-url("ovson_logo.png");
    width: 760px;
    height: 500px;
    background: transparent;
    no-frame: true;
    forward-focus: kb;

    in property <[PRow]> processes: [];
    in property <string> status-text: "Ready";
    in property <int> phase: 0;
    in property <int> selected-count: 0;

    in property <int>    update-state: 0;
    in property <string> update-version: "";
    in property <string> update-status: "";
    in property <int>    update-progress: 0;
    in property <bool>   update-available: false;

    in-out property <int> active-page: 0;
    in property <string>  build-version: "0.0.0";

    in-out property <bool>   setting-auto-inject: false;
    in-out property <bool>   setting-start-with-windows: false;
    in-out property <bool>   setting-minimize-to-tray: true;
    in-out property <bool>   setting-auto-check-updates: true;
    in-out property <int>    setting-dll-slot: 0;
    in-out property <string> setting-custom-dll-path: "";

    callback inject-clicked();
    callback close-clicked();
    callback minimize-clicked();
    callback toggle-row(int);
    callback uninject-row(int);
    callback install-update();
    callback open-github();
    callback view-changelog();
    callback settings-changed();
    callback pick-custom-dll();
    callback show-context-menu(int);

    in property <[LogLine]> log-lines: [];
    in property <string>    log-path: "";
    callback open-log-folder();
    callback clear-log();

    in property <int> dump-count: 0;
    in-out property <bool> show-report-modal: false;
    callback open-dumps-folder();
    callback report-crash-dumps();
    callback dismiss-crash-dumps();
    callback report-modal-yes();
    callback report-modal-no();

    property <bool> docked: phase >= 1;
    property <bool> chrome-on: phase >= 1;
    property <float> chrome-opacity: chrome-on ? 1.0 : 0.0;
    property <length> logo-text-size: docked ? 18px : 52px;
    property <length> logo-width: docked ? 110px : 320px;
    property <length> logo-height: docked ? 24px : 78px;
    property <length> logo-x: docked
        ? 24px
        : (root.width - logo-width) / 2;
    property <length> logo-y: docked
        ? 12px
        : (root.height - logo-height) / 2;

    Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        background: Palette.bg.with-alpha(chrome-opacity);
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border.with-alpha(chrome-opacity);
        animate background, border-color {
            duration: 600ms; easing: ease-out;
        }

        VerticalLayout {
            opacity: chrome-opacity;
            animate opacity { duration: 500ms; easing: ease-out; }

            Rectangle {
                height: 48px;
                background: transparent;

                HorizontalLayout {
                    x: (parent.width - self.preferred-width) / 2;
                    y: 11px;
                    spacing: 6px;
                    height: 26px;

                    NavButton {
                        label: "Instances";
                        active: root.active-page == 0;
                        clicked => { root.active-page = 0; }
                    }
                    NavButton {
                        label: "Settings";
                        active: root.active-page == 1;
                        clicked => { root.active-page = 1; }
                    }
                    NavButton {
                        label: "Logs";
                        active: root.active-page == 3;
                        clicked => { root.active-page = 3; }
                    }
                    NavButton {
                        label: "About";
                        active: root.active-page == 2;
                        clicked => { root.active-page = 2; }
                    }
                }

                minimize-touch := TouchArea {
                    x: parent.width - 70px;
                    y: 10px;
                    width: 28px;
                    height: 28px;
                    clicked => { root.minimize-clicked(); }
                    mouse-cursor: MouseCursor.pointer;
                    Rectangle {
                        width: parent.width; height: parent.height;
                        border-radius: 6px;
                        background: minimize-touch.has-hover ? #2b2c34 : transparent;
                        animate background { duration: 140ms; }
                    }
                    Rectangle {
                        x: (parent.width - 12px) / 2;
                        y: (parent.height - 2px) / 2;
                        width: 12px;
                        height: 2px;
                        background: minimize-touch.has-hover ? Palette.text : Palette.text-muted;
                        animate background { duration: 140ms; }
                    }
                }

                close-touch := TouchArea {
                    x: parent.width - 36px;
                    y: 10px;
                    width: 28px;
                    height: 28px;
                    clicked => { root.close-clicked(); }
                    mouse-cursor: MouseCursor.pointer;
                    Rectangle {
                        width: parent.width; height: parent.height;
                        border-radius: 6px;
                        background: close-touch.has-hover ? #2b2c34 : transparent;
                        animate background { duration: 140ms; }
                    }
                    Image {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 12px;
                        height: 12px;
                        colorize: close-touch.has-hover
                                  ? Palette.text : Palette.text-muted;
                        source: @image-url("close.svg");
                        animate colorize { duration: 140ms; }
                    }
                }

                Rectangle {
                    x: 0; y: parent.height - 1px;
                    width: parent.width; height: 1px;
                    background: Palette.border;
                }
            }

            if active-page != 0: Rectangle {
                vertical-stretch: 1;
                if active-page == 3: LogsPage {
                    width: parent.width;
                    height: parent.height;
                    lines: root.log-lines;
                    log-path: root.log-path;
                    open-log-folder => { root.open-log-folder(); }
                    clear-log => { root.clear-log(); }
                }
                if active-page == 1: SettingsPage {
                    width: parent.width;
                    height: parent.height;
                    auto-inject        <=> root.setting-auto-inject;
                    start-with-windows <=> root.setting-start-with-windows;
                    minimize-to-tray   <=> root.setting-minimize-to-tray;
                    auto-check-updates <=> root.setting-auto-check-updates;
                    dll-slot           <=> root.setting-dll-slot;
                    custom-dll-path:        root.setting-custom-dll-path;
                    settings-changed => { root.settings-changed(); }
                    pick-custom-dll => { root.pick-custom-dll(); }
                }
                if active-page == 2: AboutPage {
                    width: parent.width;
                    height: parent.height;
                    build-version: root.build-version;
                    open-github => { root.open-github(); }
                }
            }

            if active-page == 0: HorizontalLayout {
                padding-left: 28px;
                padding-right: 28px;
                padding-top: 22px;
                padding-bottom: 6px;
                Text {
                    text: "MINECRAFT INSTANCES";
                    color: Palette.text;
                    font-size: 12px;
                    font-weight: 600;
                    horizontal-stretch: 1;
                }
                Text {
                    text: processes.length == 0  ? "Waiting for Minecraft…"
                        : processes.length == 1  ? "1 detected"
                                                 : "\{processes.length} detected";
                    color: Palette.text-muted;
                    font-size: 11px;
                    horizontal-alignment: right;
                }
            }

            if active-page == 0: Rectangle {
                vertical-stretch: 1;

                if processes.length == 0: Rectangle {
                    x: 28px; y: 0;
                    width: parent.width - 56px;
                    height: 110px;
                    border-radius: 12px;
                    background: Palette.panel;
                    border-color: Palette.border;
                    border-width: 1px;

                    VerticalLayout {
                        alignment: center;
                        spacing: 6px;
                        Text {
                            text: "No Minecraft windows found";
                            color: Palette.text;
                            font-size: 15px;
                            font-weight: 600;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Launch Minecraft (Lunar / Badlion / Vanilla / Forge) — the list refreshes automatically.";
                            color: Palette.text-muted;
                            font-size: 11px;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                }

                if processes.length > 0: ScrollView {
                    x: 28px; y: 0;
                    width: parent.width - 56px;
                    height: parent.height;

                    VerticalLayout {
                        spacing: 10px;
                        for proc[i] in processes: ProcessCard {
                            data: proc;
                            clicked => { root.toggle-row(i); }
                            uninject-clicked => { root.uninject-row(i); }
                            right-clicked => { root.show-context-menu(i); }
                        }
                    }
                }
            }

            if active-page == 0: HorizontalLayout {
                padding: 16px;
                alignment: center;
                PrimaryButton {
                    label: phase == 3                ? "INJECTING…"
                         : phase == 4                ? "DONE"
                         : processes.length == 0     ? "WAITING FOR MINECRAFT"
                         : selected-count == 0       ? "SELECT AN INSTANCE"
                         : selected-count == 1       ? "INJECT"
                                                     : "INJECT \{selected-count} INSTANCES";
                    enabled: phase == 2 && selected-count > 0;
                    clicked => { root.inject-clicked(); }
                }
            }

            Rectangle {
                height: 1px;
                background: Palette.border;
            }

            Rectangle {
                height: phase >= 2 && dump-count > 0 ? 40px : 0px;
                opacity: phase >= 2 && dump-count > 0 ? 1.0 : 0.0;
                animate height, opacity { duration: 350ms; easing: ease-in-out; }
                clip: true;
                background: #2a1f12;
                border-color: #c08440;
                border-width: 1px;
                border-radius: 8px;

                HorizontalLayout {
                    padding-left: 14px;
                    padding-right: 6px;
                    spacing: 10px;
                    alignment: center;

                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        Text {
                            text: dump-count == 1
                                ? "1 crash dump from a previous session is waiting."
                                : dump-count + " crash dumps from previous sessions are waiting.";
                            color: #f4d4a8;
                            font-size: 12px;
                            font-weight: 600;
                            overflow: elide;
                        }
                    }
                    Rectangle {
                        width: 96px; height: 28px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 6px;
                        background: open-touch.has-hover
                                    ? Palette.card-hover : transparent;
                        border-width: 1px;
                        border-color: #c08440;
                        open-touch := TouchArea {
                            clicked => { root.open-dumps-folder(); }
                            mouse-cursor: MouseCursor.pointer;
                        }
                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "View";
                            color: #f4d4a8;
                            font-weight: 600;
                            font-size: 10px;
                        }
                    }
                    Rectangle {
                        width: 96px; height: 28px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 6px;
                        background: report-touch.has-hover
                                    ? #c08440 : transparent;
                        border-width: 1px;
                        border-color: #c08440;
                        animate background { duration: 130ms; }
                        report-touch := TouchArea {
                            clicked => { root.show-report-modal = true; }
                            mouse-cursor: MouseCursor.pointer;
                        }
                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "Report…";
                            color: report-touch.has-hover
                                   ? Palette.bg : #f4d4a8;
                            font-weight: 700;
                            font-size: 10px;
                        }
                    }
                    Rectangle {
                        width: 28px; height: 28px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 6px;
                        background: dismiss-touch.has-hover
                                    ? Palette.card-hover : transparent;
                        dismiss-touch := TouchArea {
                            clicked => { root.dismiss-crash-dumps(); }
                            mouse-cursor: MouseCursor.pointer;
                        }
                        Image {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: 10px;
                            height: 10px;
                            colorize: dismiss-touch.has-hover ? Palette.text : Palette.text-dim;
                            source: @image-url("close.svg");
                            animate colorize { duration: 140ms; }
                        }
                    }
                }
            }

            Rectangle {
                height: phase >= 2 && update-state >= 1 && update-state <= 6 ? 40px : 0px;
                opacity: phase >= 2 && update-state >= 1 && update-state <= 6 ? 1.0 : 0.0;
                animate height, opacity { duration: 350ms; easing: ease-in-out; }
                clip: true;
                background: update-state == 2 ? #0e2418
                          : update-state == 6 ? #2a1414
                          : update-state == 1 ? #142030
                                              : #14272f;
                animate background { duration: 250ms; easing: ease-out; }
                border-color: update-state == 2 ? Palette.success
                            : update-state == 6 ? Palette.error-c
                            : update-state == 1 ? #5a8bd0
                                                : Palette.accent;
                animate border-color { duration: 250ms; easing: ease-out; }
                border-width: 1px;
                border-radius: 8px;

                HorizontalLayout {
                    padding-left: 14px;
                    padding-right: 6px;
                    spacing: 10px;
                    alignment: center;

                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: 2px;
                        Text {
                            text: update-state == 1 ? "Checking for updates…"
                                : update-state == 2 ? "You are using the latest version!"
                                : update-state == 3 ? "Update available: " + update-version
                                : update-state == 4 ? "Downloading " + update-version + "…"
                                : update-state == 5 ? "Update ready to install"
                                : update-state == 6 ? update-status
                                                    : "";
                            color: update-state == 2 ? Palette.success
                                 : update-state == 6 ? Palette.error-c
                                                     : Palette.text;
                            font-size: 12px;
                            font-weight: 600;
                            overflow: elide;
                        }
                        if update-state == 4 && update-progress < 100: Rectangle {
                            height: 3px;
                            border-radius: 1.5px;
                            background: #2a3550;
                            Rectangle {
                                x: 0; y: 0;
                                width: parent.width * update-progress / 100;
                                height: parent.height;
                                background: Palette.accent;
                                border-radius: 1.5px;
                                animate width { duration: 200ms; easing: ease-out; }
                            }
                        }
                    }

                    if update-state == 3: Rectangle {
                        width: 96px;
                        height: 28px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 6px;
                        background: changelog-touch.has-hover
                                    ? Palette.card-hover
                                    : transparent;
                        border-width: 1px;
                        border-color: Palette.border-hover;
                        animate background { duration: 130ms; easing: ease-out; }

                        changelog-touch := TouchArea {
                            clicked => { root.view-changelog(); }
                            mouse-cursor: MouseCursor.pointer;
                        }
                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "View Changes";
                            color: Palette.text-dim;
                            font-weight: 600;
                            font-size: 10px;
                        }
                    }

                    if update-state == 3 || update-state == 4 || update-state == 5: Rectangle {
                        width: 96px;
                        height: 28px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 6px;
                        background: install-touch.pressed   ? Palette.accent-dim
                                  : install-touch.has-hover ? #ffffff
                                  : update-state == 4       ? #2a3550
                                                            : #cbd5e1;
                        animate background { duration: 130ms; easing: ease-out; }
                        opacity: update-state == 4 ? 0.6 : 1.0;

                        install-touch := TouchArea {
                            enabled: update-state != 4;
                            clicked => { root.install-update(); }
                            mouse-cursor: update-state == 4
                                          ? MouseCursor.default
                                          : MouseCursor.pointer;
                        }
                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: update-state == 5 ? "RESTART"
                                : update-state == 4 ? "…"
                                                    : "INSTALL";
                            color: update-state == 4 ? Palette.text-dim
                                                     : Palette.bg;
                            font-weight: 700;
                            font-size: 11px;
                        }
                    }
                }
            }

            HorizontalLayout {
                padding-left: 28px;
                padding-right: 28px;
                padding-top: 14px;
                padding-bottom: 18px;
                Text {
                    text: status-text;
                    color: phase == 4 ? Palette.success
                         : phase == 5 ? Palette.error-c
                                      : Palette.text-dim;
                    font-size: 12px;
                    animate color { duration: 200ms; }
                    horizontal-stretch: 1;
                }
            }
        }
    }

    kb := FocusScope {
        x: 0; y: 0;
        width: 1px; height: 1px;
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.close-clicked();
                return accept;
            }
            if (event.modifiers.control && event.text == "1") {
                root.active-page = 0; return accept;
            }
            if (event.modifiers.control && event.text == "2") {
                root.active-page = 1; return accept;
            }
            if (event.modifiers.control && event.text == "3") {
                root.active-page = 2; return accept;
            }
            if (event.modifiers.control && event.text == "4") {
                root.active-page = 3; return accept;
            }
            if (event.text == Key.Return
                && root.active-page == 0
                && root.phase == 2
                && root.selected-count > 0) {
                root.inject-clicked();
                return accept;
            }
            return reject;
        }
    }

    logo := Rectangle {
        x: logo-x;
        y: logo-y;
        width: logo-width;
        height: logo-height;
        clip: false;

        animate x        { duration: 850ms; easing: ease-in-out; }
        animate y        { duration: 850ms; easing: ease-in-out; }
        animate width    { duration: 850ms; easing: ease-in-out; }
        animate height   { duration: 850ms; easing: ease-in-out; }

        HorizontalLayout {
            spacing: docked ? 8px : 16px;
            alignment: center;

            Image {
                source: @image-url("ovson_logo.png");
                image-fit: contain;
                width: parent.height;
                height: parent.height;
            }

            Text {
                text: "OVson";
                font-weight: 800;
                color: Palette.text;
                font-size: logo-text-size;
                vertical-alignment: center;
                animate font-size { duration: 850ms; easing: ease-in-out; }
            }
        }
    }

    if show-report-modal: Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        background: Palette.bg.with-alpha(0.85);
        opacity: show-report-modal ? 1.0 : 0.0;
        animate opacity { duration: 200ms; }

        TouchArea {}

        Rectangle {
            width: 440px;
            height: 200px;
            x: (root.width - self.width) / 2;
            y: (root.height - self.height) / 2;
            background: Palette.card;
            border-radius: 12px;
            border-width: 1px;
            border-color: Palette.border;

            VerticalLayout {
                padding: 24px;
                spacing: 16px;

                Text {
                    text: "Report crash dumps";
                    color: Palette.text;
                    font-size: 16px;
                    font-weight: 700;
                }

                Text {
                    text: "Would you like to open a GitHub issue to report these dumps? You will need to attach the .dmp files manually.\n\nChoose 'Delete all' if you just want to clear them.";
                    color: Palette.text-dim;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 12px;
                    alignment: end;

                    Rectangle {
                        width: 100px; height: 36px;
                        border-radius: 8px;
                        background: cancel-touch.has-hover ? Palette.card-hover : transparent;
                        border-width: 1px;
                        border-color: Palette.border-hover;
                        cancel-touch := TouchArea {
                            clicked => { root.show-report-modal = false; }
                            mouse-cursor: MouseCursor.pointer;
                        }
                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "Cancel";
                            color: Palette.text-dim;
                            font-size: 13px;
                            font-weight: 600;
                        }
                    }

                    Rectangle {
                        width: 100px; height: 36px;
                        border-radius: 8px;
                        background: delete-touch.has-hover ? #2a1414 : transparent;
                        border-width: 1px;
                        border-color: delete-touch.has-hover ? Palette.error-c : Palette.border-hover;
                        delete-touch := TouchArea {
                            clicked => { root.report-modal-no(); root.show-report-modal = false; }
                            mouse-cursor: MouseCursor.pointer;
                        }
                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "Delete all";
                            color: delete-touch.has-hover ? Palette.error-c : Palette.text-dim;
                            font-size: 13px;
                            font-weight: 600;
                        }
                    }

                    Rectangle {
                        width: 120px; height: 36px;
                        border-radius: 8px;
                        background: report-modal-touch.has-hover ? #ffffff : #ebecf0;
                        report-modal-touch := TouchArea {
                            clicked => { root.report-modal-yes(); root.show-report-modal = false; }
                            mouse-cursor: MouseCursor.pointer;
                        }
                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "Report issue";
                            color: Palette.bg;
                            font-size: 13px;
                            font-weight: 600;
                        }
                    }
                }
            }
        }
    }
}
